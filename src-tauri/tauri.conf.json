{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "pragma",
  "mainBinaryName": "pragma",
  "version": "0.1.0",
  "identifier": "dev.pragma.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "vp dev",
    "beforeBuildCommand": "vp build"
  },
  "app": {
    "windows": [
      {
        "title": "Pragma",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["windows/add-to-path.ps1", "windows/remove-from-path.ps1"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer/nsis-header.bmp",
        "sidebarImage": "icons/installer/nsis-sidebar.bmp",
        "installerHooks": "windows/path-hooks.nsh"
      },
      "wix": {
        "bannerPath": "icons/installer/msi-banner.bmp",
        "dialogImagePath": "icons/installer/msi-dialog.bmp",
        "fragmentPaths": ["windows/path-env.wxs"],
        "componentRefs": ["PragmaPathEnv"]
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "cli": {
      "description": "Pragma IDE - terminal-focused AI-native editor",
      "args": [
        {
          "name": "path",
          "index": 1,
          "takesValue": true
        }
      ]
    },
    "dialog": null
  }
}
