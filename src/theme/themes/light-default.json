{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "light-default",
    "name": "Light Default",
    "author": "Pragma Team",
    "description": "A clean, calm light theme with cool neutral surfaces and an indigo accent.",
    "version": "1.1.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "light",
    "supportedModes": ["light"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#ffffff",
        "surface": "#f6f7f9",
        "elevated": "#edeef2",
        "input": "#ffffff",
        "hover": "rgba(15, 23, 42, 0.04)",
        "active": "rgba(79, 94, 208, 0.10)",
        "overlay": "rgba(15, 23, 42, 0.35)"
      },
      "foreground": {
        "default": "#1c1f26",
        "muted": "#5a6270",
        "subtle": "#98a1af",
        "inverse": "#ffffff"
      },
      "accent": {
        "default": "#4f5ed0",
        "subtle": "rgba(79, 94, 208, 0.10)",
        "glow": "rgba(79, 94, 208, 0.25)"
      },
      "border": {
        "default": "rgba(15, 23, 42, 0.09)",
        "subtle": "rgba(15, 23, 42, 0.05)",
        "focus": "rgba(79, 94, 208, 0.45)"
      },
      "status": {
        "success": "#1f9d6e",
        "successBg": "rgba(31, 157, 110, 0.10)",
        "warning": "#c28a1f",
        "warningBg": "rgba(194, 138, 31, 0.10)",
        "error": "#d6455a",
        "errorBg": "rgba(214, 69, 90, 0.10)",
        "info": "#3b7fe0",
        "infoBg": "rgba(59, 127, 224, 0.10)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#7c5cd6"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(79, 94, 208, 0.18)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(15, 23, 42, 0.14)",
        "thumbHover": "rgba(15, 23, 42, 0.24)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(15, 23, 42, 0.025)",
        "highlight": "rgba(79, 94, 208, 0.05)"
      },
      "syntax": {
        "keyword": "#7c5cd6",
        "string": "#1f8a55",
        "comment": "{colors.foreground.subtle}",
        "function": "#3b6fd4",
        "variable": "{colors.foreground.default}",
        "number": "#c2600c",
        "type": "#2b6cb0",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "#fbfbfc",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#1c1f26",
        "red": "#d6455a",
        "green": "#1f9d6e",
        "yellow": "#c28a1f",
        "blue": "#4f5ed0",
        "magenta": "#7c5cd6",
        "cyan": "#0e8fa3",
        "white": "#5a6270"
      },
      "ansiBright": {
        "black": "#4a5160",
        "red": "#e35d6a",
        "green": "#3fb68b",
        "yellow": "#e0a94e",
        "blue": "#6e7bf2",
        "magenta": "#a78bfa",
        "cyan": "#22b8cf",
        "white": "#1c1f26"
      }
    },

    "layout": {
      "headerHeight": 40,
      "tabHeight": 36,
      "statusbarHeight": 24,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 40,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
