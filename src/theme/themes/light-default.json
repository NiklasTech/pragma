{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "light-default",
    "name": "Light Default",
    "author": "Pragma Team",
    "description": "A clean, high-contrast light theme for bright environments.",
    "version": "1.0.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "light",
    "supportedModes": ["light"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#ffffff",
        "surface": "#fafafa",
        "elevated": "#f4f4f5",
        "input": "#ffffff",
        "hover": "rgba(0, 0, 0, 0.04)",
        "active": "rgba(37, 99, 235, 0.10)",
        "overlay": "rgba(0, 0, 0, 0.35)"
      },
      "foreground": {
        "default": "#18181b",
        "muted": "#52525b",
        "subtle": "#a1a1aa",
        "inverse": "#ffffff"
      },
      "accent": {
        "default": "#2563eb",
        "subtle": "rgba(37, 99, 235, 0.10)",
        "glow": "rgba(37, 99, 235, 0.25)"
      },
      "border": {
        "default": "rgba(0, 0, 0, 0.10)",
        "subtle": "rgba(0, 0, 0, 0.06)",
        "focus": "rgba(37, 99, 235, 0.50)"
      },
      "status": {
        "success": "#16a34a",
        "successBg": "rgba(22, 163, 74, 0.10)",
        "warning": "#d97706",
        "warningBg": "rgba(217, 119, 6, 0.10)",
        "error": "#dc2626",
        "errorBg": "rgba(220, 38, 38, 0.10)",
        "info": "#2563eb",
        "infoBg": "rgba(37, 99, 235, 0.10)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#9333ea"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(37, 99, 235, 0.20)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(0, 0, 0, 0.16)",
        "thumbHover": "rgba(0, 0, 0, 0.26)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(0, 0, 0, 0.02)",
        "highlight": "rgba(37, 99, 235, 0.05)"
      },
      "syntax": {
        "keyword": "#9333ea",
        "string": "#15803d",
        "comment": "{colors.foreground.subtle}",
        "function": "#2563eb",
        "variable": "{colors.foreground.default}",
        "number": "#c2410c",
        "type": "#0369a1",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#18181b",
        "red": "#dc2626",
        "green": "#16a34a",
        "yellow": "#d97706",
        "blue": "#2563eb",
        "magenta": "#9333ea",
        "cyan": "#0891b2",
        "white": "#71717a"
      },
      "ansiBright": {
        "black": "#3f3f46",
        "red": "#ef4444",
        "green": "#22c55e",
        "yellow": "#f59e0b",
        "blue": "#3b82f6",
        "magenta": "#a855f7",
        "cyan": "#06b6d4",
        "white": "#f4f4f5"
      }
    },

    "layout": {
      "headerHeight": 48,
      "tabHeight": 34,
      "statusbarHeight": 26,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 48,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
