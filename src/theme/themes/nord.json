{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "nord",
    "name": "Nord",
    "author": "Pragma Team",
    "description": "An arctic, north-bluish dark theme. Cool slate surfaces with a frosty cyan accent.",
    "version": "1.0.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "dark",
    "supportedModes": ["dark"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#242933",
        "surface": "#2e3440",
        "elevated": "#3b4252",
        "input": "#434c5e",
        "hover": "rgba(216, 222, 233, 0.05)",
        "active": "rgba(136, 192, 208, 0.14)",
        "overlay": "rgba(0, 0, 0, 0.60)"
      },
      "foreground": {
        "default": "#eceff4",
        "muted": "#d8dee9",
        "subtle": "#7b88a1",
        "inverse": "#2e3440"
      },
      "accent": {
        "default": "#88c0d0",
        "subtle": "rgba(136, 192, 208, 0.14)",
        "glow": "rgba(136, 192, 208, 0.30)"
      },
      "border": {
        "default": "rgba(216, 222, 233, 0.08)",
        "subtle": "rgba(216, 222, 233, 0.05)",
        "focus": "rgba(136, 192, 208, 0.50)"
      },
      "status": {
        "success": "#a3be8c",
        "successBg": "rgba(163, 190, 140, 0.12)",
        "warning": "#ebcb8b",
        "warningBg": "rgba(235, 203, 139, 0.12)",
        "error": "#bf616a",
        "errorBg": "rgba(191, 97, 106, 0.12)",
        "info": "#81a1c1",
        "infoBg": "rgba(129, 161, 193, 0.12)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#b48ead"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(136, 192, 208, 0.25)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(216, 222, 233, 0.12)",
        "thumbHover": "rgba(216, 222, 233, 0.20)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(216, 222, 233, 0.03)",
        "highlight": "rgba(136, 192, 208, 0.06)"
      },
      "syntax": {
        "keyword": "#81a1c1",
        "string": "#a3be8c",
        "comment": "{colors.foreground.subtle}",
        "function": "#88c0d0",
        "variable": "{colors.foreground.default}",
        "number": "#b48ead",
        "type": "#8fbcbb",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "#21252e",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#3b4252",
        "red": "#bf616a",
        "green": "#a3be8c",
        "yellow": "#ebcb8b",
        "blue": "#81a1c1",
        "magenta": "#b48ead",
        "cyan": "#88c0d0",
        "white": "#d8dee9"
      },
      "ansiBright": {
        "black": "#4c566a",
        "red": "#d06f79",
        "green": "#b1d196",
        "yellow": "#f0d399",
        "blue": "#8fb0d1",
        "magenta": "#c39bbd",
        "cyan": "#96cddb",
        "white": "#eceff4"
      }
    },

    "layout": {
      "headerHeight": 40,
      "tabHeight": 36,
      "statusbarHeight": 24,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 40,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
