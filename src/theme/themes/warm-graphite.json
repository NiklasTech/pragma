{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "pragma-dark",
    "name": "Pragma Dark",
    "author": "Pragma Team",
    "description": "A deep, high-contrast dark theme with electric blue accents. Built for focus.",
    "version": "2.0.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "dark",
    "supportedModes": ["dark"],
    "preferredEditorTheme": "pragma-dark"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#09090b",
        "surface": "#0f0f11",
        "elevated": "#151519",
        "input": "#1a1a1f",
        "hover": "rgba(255, 255, 255, 0.05)",
        "active": "rgba(43, 127, 255, 0.10)",
        "overlay": "rgba(0, 0, 0, 0.65)"
      },
      "foreground": {
        "default": "#f4f4f5",
        "muted": "#a1a1aa",
        "subtle": "#71717a",
        "inverse": "#09090b"
      },
      "accent": {
        "default": "#2b7fff",
        "subtle": "rgba(43, 127, 255, 0.12)",
        "glow": "rgba(43, 127, 255, 0.35)"
      },
      "border": {
        "default": "rgba(255, 255, 255, 0.08)",
        "subtle": "rgba(255, 255, 255, 0.05)",
        "focus": "rgba(43, 127, 255, 0.50)"
      },
      "status": {
        "success": "#22c55e",
        "successBg": "rgba(34, 197, 94, 0.12)",
        "warning": "#f59e0b",
        "warningBg": "rgba(245, 158, 11, 0.12)",
        "error": "#ef4444",
        "errorBg": "rgba(239, 68, 68, 0.12)",
        "info": "#3b82f6",
        "infoBg": "rgba(59, 130, 246, 0.12)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#c084fc"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(43, 127, 255, 0.25)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(255, 255, 255, 0.12)",
        "thumbHover": "rgba(255, 255, 255, 0.22)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(255, 255, 255, 0.03)",
        "highlight": "rgba(43, 127, 255, 0.06)"
      },
      "syntax": {
        "keyword": "#c084fc",
        "string": "#86efac",
        "comment": "{colors.foreground.subtle}",
        "function": "#60a5fa",
        "variable": "{colors.foreground.default}",
        "number": "#fdba74",
        "type": "#93c5fd",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#09090b",
        "red": "#ef4444",
        "green": "#22c55e",
        "yellow": "#f59e0b",
        "blue": "#2b7fff",
        "magenta": "#c084fc",
        "cyan": "#22d3ee",
        "white": "#a1a1aa"
      },
      "ansiBright": {
        "black": "#27272a",
        "red": "#f87171",
        "green": "#4ade80",
        "yellow": "#fbbf24",
        "blue": "#60a5fa",
        "magenta": "#d8b4fe",
        "cyan": "#67e8f9",
        "white": "#f4f4f5"
      }
    },

    "layout": {
      "headerHeight": 48,
      "tabHeight": 34,
      "statusbarHeight": 26,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 48,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
