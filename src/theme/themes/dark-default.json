{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "dark-default",
    "name": "Dark Default",
    "author": "Pragma Team",
    "description": "A calm, technical dark theme with cool slate surfaces and an indigo accent. Built for focus.",
    "version": "2.1.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "dark",
    "supportedModes": ["dark"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#0b0d10",
        "surface": "#101318",
        "elevated": "#161a21",
        "input": "#1a1f28",
        "hover": "rgba(255, 255, 255, 0.04)",
        "active": "rgba(110, 123, 242, 0.12)",
        "overlay": "rgba(0, 0, 0, 0.60)"
      },
      "foreground": {
        "default": "#e8eaee",
        "muted": "#9ba3af",
        "subtle": "#646c7a",
        "inverse": "#0b0d10"
      },
      "accent": {
        "default": "#6e7bf2",
        "subtle": "rgba(110, 123, 242, 0.14)",
        "glow": "rgba(110, 123, 242, 0.30)"
      },
      "border": {
        "default": "rgba(255, 255, 255, 0.06)",
        "subtle": "rgba(255, 255, 255, 0.04)",
        "focus": "rgba(110, 123, 242, 0.50)"
      },
      "status": {
        "success": "#3fb68b",
        "successBg": "rgba(63, 182, 139, 0.12)",
        "warning": "#e0a94e",
        "warningBg": "rgba(224, 169, 78, 0.12)",
        "error": "#e35d6a",
        "errorBg": "rgba(227, 93, 106, 0.12)",
        "info": "#5b9cf5",
        "infoBg": "rgba(91, 156, 245, 0.12)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#a78bfa"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(110, 123, 242, 0.25)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(255, 255, 255, 0.10)",
        "thumbHover": "rgba(255, 255, 255, 0.18)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(255, 255, 255, 0.025)",
        "highlight": "rgba(110, 123, 242, 0.06)"
      },
      "syntax": {
        "keyword": "#a78bfa",
        "string": "#7fc8a9",
        "comment": "{colors.foreground.subtle}",
        "function": "#7ab8f5",
        "variable": "{colors.foreground.default}",
        "number": "#e8b87d",
        "type": "#8ab4f5",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "#090b0e",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#0b0d10",
        "red": "#e35d6a",
        "green": "#3fb68b",
        "yellow": "#e0a94e",
        "blue": "#6e7bf2",
        "magenta": "#a78bfa",
        "cyan": "#4ec9d8",
        "white": "#9ba3af"
      },
      "ansiBright": {
        "black": "#2a2f3a",
        "red": "#ed7f8b",
        "green": "#5fcfa5",
        "yellow": "#edbf72",
        "blue": "#8b96f6",
        "magenta": "#bba5f9",
        "cyan": "#7adbe7",
        "white": "#e8eaee"
      }
    },

    "layout": {
      "headerHeight": 40,
      "tabHeight": 36,
      "statusbarHeight": 24,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 40,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
