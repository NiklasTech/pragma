{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "tokyo-night",
    "name": "Tokyo Night",
    "author": "Pragma Team",
    "description": "A dark, low-contrast theme inspired by the Tokyo Night palette.",
    "version": "1.0.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "dark",
    "supportedModes": ["dark"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#1a1b26",
        "surface": "#16161e",
        "elevated": "#1f2336",
        "input": "#24283b",
        "hover": "rgba(192, 202, 245, 0.05)",
        "active": "rgba(122, 162, 247, 0.12)",
        "overlay": "rgba(0, 0, 0, 0.55)"
      },
      "foreground": {
        "default": "#c0caf5",
        "muted": "#a9b1d6",
        "subtle": "#565f89",
        "inverse": "#1a1b26"
      },
      "accent": {
        "default": "#7aa2f7",
        "subtle": "rgba(122, 162, 247, 0.15)",
        "glow": "rgba(122, 162, 247, 0.35)"
      },
      "border": {
        "default": "rgba(192, 202, 245, 0.10)",
        "subtle": "rgba(192, 202, 245, 0.06)",
        "focus": "rgba(122, 162, 247, 0.50)"
      },
      "status": {
        "success": "#9ece6a",
        "successBg": "rgba(158, 206, 106, 0.12)",
        "warning": "#e0af68",
        "warningBg": "rgba(224, 175, 104, 0.12)",
        "error": "#f7768e",
        "errorBg": "rgba(247, 118, 142, 0.12)",
        "info": "#7aa2f7",
        "infoBg": "rgba(122, 162, 247, 0.12)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#bb9af7"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(122, 162, 247, 0.25)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(192, 202, 245, 0.12)",
        "thumbHover": "rgba(192, 202, 245, 0.22)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(192, 202, 245, 0.03)",
        "highlight": "rgba(122, 162, 247, 0.06)"
      },
      "syntax": {
        "keyword": "#bb9af7",
        "string": "#9ece6a",
        "comment": "{colors.foreground.subtle}",
        "function": "#7aa2f7",
        "variable": "{colors.foreground.default}",
        "number": "#ff9e64",
        "type": "#2ac3de",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#1a1b26",
        "red": "#f7768e",
        "green": "#9ece6a",
        "yellow": "#e0af68",
        "blue": "#7aa2f7",
        "magenta": "#bb9af7",
        "cyan": "#2ac3de",
        "white": "#a9b1d6"
      },
      "ansiBright": {
        "black": "#414868",
        "red": "#ff8fab",
        "green": "#c3e88d",
        "yellow": "#ffdb96",
        "blue": "#a0c6ff",
        "magenta": "#d5b4fe",
        "cyan": "#73daca",
        "white": "#c0caf5"
      }
    },

    "layout": {
      "headerHeight": 40,
      "tabHeight": 36,
      "statusbarHeight": 24,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 40,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
