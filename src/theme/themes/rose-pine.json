{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "rose-pine",
    "name": "Rosé Pine",
    "author": "Pragma Team",
    "description": "A soho-vintage dark theme with deep violet surfaces and a soft iris accent. Warm and elegant.",
    "version": "1.0.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "dark",
    "supportedModes": ["dark"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#191724",
        "surface": "#1f1d2e",
        "elevated": "#26233a",
        "input": "#2a283d",
        "hover": "rgba(224, 222, 244, 0.05)",
        "active": "rgba(196, 167, 231, 0.13)",
        "overlay": "rgba(0, 0, 0, 0.60)"
      },
      "foreground": {
        "default": "#e0def4",
        "muted": "#908caa",
        "subtle": "#6e6a86",
        "inverse": "#191724"
      },
      "accent": {
        "default": "#c4a7e7",
        "subtle": "rgba(196, 167, 231, 0.14)",
        "glow": "rgba(196, 167, 231, 0.30)"
      },
      "border": {
        "default": "rgba(224, 222, 244, 0.07)",
        "subtle": "rgba(224, 222, 244, 0.04)",
        "focus": "rgba(196, 167, 231, 0.50)"
      },
      "status": {
        "success": "#9ccfd8",
        "successBg": "rgba(156, 207, 216, 0.12)",
        "warning": "#f6c177",
        "warningBg": "rgba(246, 193, 119, 0.12)",
        "error": "#eb6f92",
        "errorBg": "rgba(235, 111, 146, 0.12)",
        "info": "#31748f",
        "infoBg": "rgba(49, 116, 143, 0.18)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "#9ccfd8",
        "untrackedBg": "{colors.status.successBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#ebbcba"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(196, 167, 231, 0.24)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(224, 222, 244, 0.10)",
        "thumbHover": "rgba(224, 222, 244, 0.18)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(224, 222, 244, 0.03)",
        "highlight": "rgba(196, 167, 231, 0.06)"
      },
      "syntax": {
        "keyword": "#c4a7e7",
        "string": "#f6c177",
        "comment": "{colors.foreground.subtle}",
        "function": "#ebbcba",
        "variable": "{colors.foreground.default}",
        "number": "#eb6f92",
        "type": "#9ccfd8",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "{colors.foreground.default}",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "#15121f",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#26233a",
        "red": "#eb6f92",
        "green": "#9ccfd8",
        "yellow": "#f6c177",
        "blue": "#31748f",
        "magenta": "#c4a7e7",
        "cyan": "#ebbcba",
        "white": "#908caa"
      },
      "ansiBright": {
        "black": "#6e6a86",
        "red": "#f085a3",
        "green": "#b0dbe2",
        "yellow": "#f8cf92",
        "blue": "#4a8fae",
        "magenta": "#d2baee",
        "cyan": "#f2cfcd",
        "white": "#e0def4"
      }
    },

    "layout": {
      "headerHeight": 40,
      "tabHeight": 36,
      "statusbarHeight": 24,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 40,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
