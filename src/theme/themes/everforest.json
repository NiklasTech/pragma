{
  "$schema": "https://pragma.dev/theme-schema/v1.json",
  "format": "pragma-theme-v1",

  "metadata": {
    "id": "everforest",
    "name": "Everforest",
    "author": "Pragma Team",
    "description": "A forest-inspired dark theme with warm green surfaces and a soft moss accent. Easy on the eyes.",
    "version": "1.0.0",
    "license": "MIT"
  },

  "appearance": {
    "defaultMode": "dark",
    "supportedModes": ["dark"],
    "preferredEditorTheme": "dark-default"
  },

  "tokens": {
    "colors": {
      "background": {
        "root": "#272e33",
        "surface": "#2d353b",
        "elevated": "#343f44",
        "input": "#3d484d",
        "hover": "rgba(211, 198, 170, 0.05)",
        "active": "rgba(167, 192, 128, 0.13)",
        "overlay": "rgba(0, 0, 0, 0.60)"
      },
      "foreground": {
        "default": "#d3c6aa",
        "muted": "#9da9a0",
        "subtle": "#6b7a72",
        "inverse": "#272e33"
      },
      "accent": {
        "default": "#a7c080",
        "subtle": "rgba(167, 192, 128, 0.14)",
        "glow": "rgba(167, 192, 128, 0.30)"
      },
      "border": {
        "default": "rgba(211, 198, 170, 0.08)",
        "subtle": "rgba(211, 198, 170, 0.05)",
        "focus": "rgba(167, 192, 128, 0.50)"
      },
      "status": {
        "success": "#a7c080",
        "successBg": "rgba(167, 192, 128, 0.12)",
        "warning": "#dbbc7f",
        "warningBg": "rgba(219, 188, 127, 0.12)",
        "error": "#e67e80",
        "errorBg": "rgba(230, 126, 128, 0.12)",
        "info": "#7fbbb3",
        "infoBg": "rgba(127, 187, 179, 0.12)"
      },
      "git": {
        "added": "{colors.status.success}",
        "addedBg": "{colors.status.successBg}",
        "modified": "{colors.status.warning}",
        "modifiedBg": "{colors.status.warningBg}",
        "deleted": "{colors.status.error}",
        "deletedBg": "{colors.status.errorBg}",
        "untracked": "{colors.status.info}",
        "untrackedBg": "{colors.status.infoBg}",
        "ignored": "{colors.foreground.subtle}",
        "conflict": "#d699b6"
      },
      "thread": {
        "default": "{colors.accent.subtle}",
        "active": "{colors.accent.default}"
      },
      "selection": "rgba(167, 192, 128, 0.24)",
      "scrollbar": {
        "track": "transparent",
        "thumb": "rgba(211, 198, 170, 0.12)",
        "thumbHover": "rgba(211, 198, 170, 0.20)"
      }
    },

    "editor": {
      "background": "{colors.background.root}",
      "foreground": "{colors.foreground.default}",
      "selection": "{colors.selection}",
      "cursor": "{colors.accent.default}",
      "gutter": {
        "background": "{colors.background.root}",
        "foreground": "{colors.foreground.subtle}",
        "activeBackground": "{colors.background.surface}"
      },
      "line": {
        "active": "rgba(211, 198, 170, 0.03)",
        "highlight": "rgba(167, 192, 128, 0.06)"
      },
      "syntax": {
        "keyword": "#e67e80",
        "string": "#a7c080",
        "comment": "{colors.foreground.subtle}",
        "function": "#83c092",
        "variable": "{colors.foreground.default}",
        "number": "#d699b6",
        "type": "#dbbc7f",
        "tag": "{colors.status.error}",
        "attribute": "{colors.accent.default}",
        "property": "#7fbbb3",
        "operator": "{colors.foreground.muted}"
      }
    },

    "terminal": {
      "background": "#232a2e",
      "foreground": "{colors.foreground.default}",
      "cursor": "{colors.accent.default}",
      "cursorAccent": "{colors.accent.default}",
      "selection": "{colors.selection}",
      "ansi": {
        "black": "#343f44",
        "red": "#e67e80",
        "green": "#a7c080",
        "yellow": "#dbbc7f",
        "blue": "#7fbbb3",
        "magenta": "#d699b6",
        "cyan": "#83c092",
        "white": "#9da9a0"
      },
      "ansiBright": {
        "black": "#4f5b58",
        "red": "#f08e90",
        "green": "#b6d093",
        "yellow": "#e5c890",
        "blue": "#93cbc4",
        "magenta": "#e0a9c5",
        "cyan": "#98d0a6",
        "white": "#d3c6aa"
      }
    },

    "layout": {
      "headerHeight": 40,
      "tabHeight": 36,
      "statusbarHeight": 24,
      "breadcrumbHeight": 28,
      "inputbarHeight": 42,
      "sidebarWidth": 260,
      "sidebarCollapsedWidth": 40,
      "sidebarMinWidth": 180,
      "sidebarMaxWidth": 480,
      "panelMinHeight": 160,
      "panelDefaultHeight": 240,
      "rowHeight": 26,
      "padding": {
        "xs": 4,
        "sm": 6,
        "md": 8,
        "lg": 12
      }
    },

    "typography": {
      "ui": {
        "2xs": "9px",
        "xs": "11px",
        "sm": "12px",
        "base": "13px",
        "md": "14px",
        "lg": "16px"
      },
      "editor": "14px",
      "lineHeight": {
        "ui": {
          "2xs": "12px",
          "xs": "14px",
          "sm": "16px",
          "base": "20px",
          "md": "22px",
          "lg": "24px"
        },
        "editor": "22px"
      }
    },

    "motion": {
      "duration": {
        "fast": "150ms",
        "base": "200ms",
        "slow": "250ms",
        "layout": "300ms"
      },
      "ease": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "out": "cubic-bezier(0.16, 1, 0.3, 1)",
        "inOut": "cubic-bezier(0.2, 0, 0, 1)",
        "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      }
    }
  }
}
